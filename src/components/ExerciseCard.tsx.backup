import { CheckCircle2, Clock, Target, Lightbulb, Info } from 'lucide-react';

interface ExerciseCardProps {
  exercise: {
    id: string;
    title: string;
    description: string;
    duration: number;
    difficulty: 'beginner' | 'intermediate' | 'advanced';
    category: string;
    completed: boolean;
    instructions?: string[];
    tips?: string[];
  };
  index: number;
  onToggle: (id: string) => void;
}

export default function ExerciseCard({ exercise, onToggle }: ExerciseCardProps) {
  const {
    id,
    title,
    description,
    duration,
    difficulty,
    category,
    completed,
    instructions = [],
    tips = [],
  } = exercise;

  const difficultyColors = {
    beginner: 'bg-green-100 text-green-700',
    intermediate: 'bg-yellow-100 text-yellow-700',
    advanced: 'bg-red-100 text-red-700',
  };

  return (
    <div className={`bg-white rounded-xl shadow-sm border transition-all ${
      completed ? 'border-green-200 bg-green-50/30' : 'border-surface-200'
    }`}>
      <div className="p-5">
        <div className="flex items-start gap-4">
          {/* Checkbox Button */}
          <button
            onClick={() => onToggle(id)}
            className={`mt-1 flex-shrink-0 w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all ${
              completed
                ? 'bg-green-500 border-green-500'
                : 'border-surface-300 hover:border-brand-400'
            }`}
          >
            {completed && <CheckCircle2 className="w-4 h-4 text-white" />}
          </button>

          {/* Content */}
          <div className="flex-1">
            <div className="flex items-center gap-2 mb-2 flex-wrap">
              <h3 className="font-semibold text-surface-900">{title}</h3>
              <span className={`text-xs px-2 py-0.5 rounded-full ${difficultyColors[difficulty]}`}>
                {difficulty}
              </span>
              <span className="text-xs bg-surface-100 text-surface-600 px-2 py-0.5 rounded-full">
                {category}
              </span>
            </div>
            
            <p className="text-surface-600 text-sm mb-3">{description}</p>
            
            <div className="flex items-center gap-4 text-sm text-surface-500">
              <div className="flex items-center gap-1">
                <Clock className="w-4 h-4" />
                <span>{duration} min</span>
              </div>
              <div className="flex items-center gap-1">
                <Target className="w-4 h-4" />
                <span>Focus: {category}</span>
              </div>
            </div>

            {/* Instructions */}
            {instructions && instructions.length > 0 && (
              <div className="mt-3 pt-3 border-t border-surface-100">
                <div className="flex items-center gap-1 text-sm font-medium text-surface-700 mb-1">
                  <Info className="w-4 h-4" />
                  <span>Instructions</span>
                </div>
                <ul className="text-sm text-surface-600 list-disc list-inside space-y-1">
                  {instructions.map((instruction, idx) => (
                    <li key={idx}>{instruction}</li>
                  ))}
                </ul>
              </div>
            )}

            {/* Tips */}
            {tips && tips.length > 0 && (
              <div className="mt-3 pt-2">
                <div className="flex items-center gap-1 text-sm font-medium text-amber-600">
                  <Lightbulb className="w-4 h-4" />
                  <span>Pro Tip</span>
                </div>
                <p className="text-sm text-amber-600">{tips[0]}</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}